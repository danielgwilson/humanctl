{
  "name": "humanctl",
  "version": "0.17.5",
  "description": "A control plane for the human bottleneck.",
  "main": "dist/electron/main.js",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.6.2",
  "bin": {
    "humanctl": "dist/bin/humanctl.js"
  },
  "files": [
    ".agents/",
    "dist/bin/",
    "dist/lib/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && npm run build:lib",
    "build:lib": "tsup",
    "typecheck": "tsc -p tsconfig.backend.json --noEmit",
    "start": "next start",
    "lint": "eslint .",
    "cli:init": "node ./dist/bin/humanctl.js init .",
    "cli:status": "node ./dist/bin/humanctl.js status .",
    "pulse:selftest": "tsx lib/pulse.selftest.ts",
    "reader:selftest": "tsx lib/reader.selftest.ts",
    "commands:selftest": "tsx lib/commands.selftest.ts",
    "perf:selftest": "npm run build:lib && npm run build:renderer-vite && node scripts/perf-selftest/run.js",
    "perf:logic-selftest": "tsx scripts/perf-selftest/logic.selftest.ts",
    "desktop": "npm run build:lib && electron dist/electron/main.js",
    "renderer": "npm --prefix electron/renderer-vite run dev",
    "renderer:build": "npm --prefix electron/renderer-vite run build:browser",
    "renderer:serve": "npm run renderer:build && tsx scripts/serve-static.ts --dir electron/renderer-vite/dist --port 4188",
    "desktop:sessions": "tsx lib/sessions.ts",
    "build:renderer-vite": "cd electron/renderer-vite && ([ -d node_modules ] || npm ci) && npm run build",
    "app:build": "npm run build:lib && npm run build:renderer-vite && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --dir",
    "app:dmg": "npm run build:lib && npm run build:renderer-vite && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "app:install": "npm run app:build && npm run perf:selftest && bash scripts/install-app.sh && npm run smoke:packaged",
    "smoke:packaged": "bash scripts/smoke-packaged.sh",
    "app:release": "npm run build:lib && npm run build:renderer-vite && electron-builder --mac dmg --config.mac.notarize=true",
    "notch:generate": "cd attic/notch/macos && xcodegen generate",
    "notch:build": "cd attic/notch/macos && xcodebuild -project HumanctlNotch.xcodeproj -scheme HumanctlNotch -configuration Debug -derivedDataPath .deriveddata build CODE_SIGNING_ALLOWED=NO",
    "notch:open": "pkill -x HumanctlNotch || true && open -a ./attic/notch/macos/.deriveddata/Build/Products/Debug/HumanctlNotch.app",
    "notch:run": "npm run notch:build && npm run notch:open"
  },
  "build": {
    "appId": "com.danielgwilson.humanctl",
    "productName": "humanctl",
    "asar": true,
    "files": [
      "dist/electron/**/*",
      "dist/lib/**/*",
      "electron/renderer-vite/dist-electron-vite/renderer/**/*",
      "electron/assets/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "directories": {
      "buildResources": "electron/assets"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "electron/assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dir"
      ]
    }
  },
  "homepage": "https://humanctl.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielgwilson/humanctl.git"
  },
  "bugs": {
    "url": "https://github.com/danielgwilson/humanctl/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agents",
    "human-in-the-loop",
    "orchestration",
    "ui",
    "cli"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.6",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
