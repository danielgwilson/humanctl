{
  "name": "humanctl",
  "version": "0.16.0",
  "description": "A control plane for the human bottleneck.",
  "main": "electron/main.js",
  "bin": {
    "humanctl": "bin/humanctl.js"
  },
  "files": [
    ".agents/",
    "bin/",
    "lib/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "cli:init": "node ./bin/humanctl.js init .",
    "cli:status": "node ./bin/humanctl.js status .",
    "pulse:selftest": "node lib/pulse.selftest.js",
    "reader:selftest": "node lib/reader.selftest.js",
    "commands:selftest": "node lib/commands.selftest.js",
    "perf:selftest": "node scripts/perf-selftest/run.js",
    "perf:logic-selftest": "node scripts/perf-selftest/logic.selftest.js",
    "desktop": "electron electron/main.js",
    "renderer": "python3 -m http.server 4173 --directory electron/renderer",
    "desktop:sessions": "node lib/sessions.js",
    "app:build": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --dir",
    "app:dmg": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "app:install": "npm run app:build && npm run perf:selftest && bash scripts/install-app.sh",
    "app:release": "electron-builder --mac dmg --config.mac.notarize=true",
    "notch:generate": "cd attic/notch/macos && xcodegen generate",
    "notch:build": "cd attic/notch/macos && xcodebuild -project HumanctlNotch.xcodeproj -scheme HumanctlNotch -configuration Debug -derivedDataPath .deriveddata build CODE_SIGNING_ALLOWED=NO",
    "notch:open": "pkill -x HumanctlNotch || true && open -a ./attic/notch/macos/.deriveddata/Build/Products/Debug/HumanctlNotch.app",
    "notch:run": "npm run notch:build && npm run notch:open"
  },
  "build": {
    "appId": "com.danielgwilson.humanctl",
    "productName": "humanctl",
    "asar": true,
    "files": [
      "electron/**/*",
      "lib/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "directories": {
      "buildResources": "electron/assets"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "electron/assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dir"
      ]
    }
  },
  "homepage": "https://humanctl.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielgwilson/humanctl.git"
  },
  "bugs": {
    "url": "https://github.com/danielgwilson/humanctl/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agents",
    "human-in-the-loop",
    "orchestration",
    "ui",
    "cli"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.6",
    "typescript": "5.9.3"
  }
}
