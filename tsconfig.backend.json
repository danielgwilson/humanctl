{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["lib/**/*.ts", "bin/**/*.ts", "electron/main.ts", "electron/preload.ts"],
  "exclude": ["node_modules", "dist", ".next", "src", "electron/renderer-vite"]
}
